{
  "comments": {
    "lineComment": "#",
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{",   "close": "}" },
    { "open": "[",   "close": "]" },
    { "open": "(",   "close": ")" },
    { "open": "'",   "close": "'",   "notIn": ["string"] },
    { "open": "\"",  "close": "\"",  "notIn": ["string"] },
    { "open": "`",   "close": "`",   "notIn": ["string"] },
    { "open": "/**", "close": " */", "notIn": ["string"] }
  ],
  "autoCloseBefore": ";:.,=}])> \n\t",
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "onEnterRules": [
    // e.g. /** | */
    {
      "beforeText": "^\\s*/\\*\\*(?!/)([^\\*]|\\*(?!/))*$",
      "afterText": "^\\s*\\*/$",
      "action": {
        "indent": "indentOutdent",
        "appendText": " * "
      }
    },
    // e.g. /** ...|
    {
      "beforeText": "^\\s*/\\*\\*(?!.*\\*/)$",
      "action": {
        "indent": "none",
        "appendText": " * "
      }
    },
    // e.g.  */|
    {
      "beforeText": "^(\\t| {2})* \\*/\\s*$",
      "action": {
        "indent": "none",
        "removeText": 1
      }
    },
    {
			// e.g.  *-----*/|
			"beforeText": {
				"pattern": "^(\\t| {2})* \\*[^/]*\\*/\\s*$"
			},
			"action": {
				"indent": "none",
				"removeText": 1
			},
		},
		{
			// e.g.  * ...|
			"beforeText": {
				"pattern": "^\\s*\\*( ([^\\*]|\\*(?!/))*)?$"
			},
			"previousLineText": {
				"pattern": "(?=^(\\s*(/\\*\\*|\\*)).*)(?=(?!(\\s*\\*/)))"
			},
			"action": {
				"indent": "none",
				"appendText": "* "
			}
		},
    // Add // when pressing enter from inside line comment
    {
      "beforeText": "(?<!\\\\)(?<!\\w:)//.*",
      "afterText": "^(?!\\s*$).+",
      "action": {
        "indent": "none",
        "appendText": "// "
      }
    }
  ]
}
