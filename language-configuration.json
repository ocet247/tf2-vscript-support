{
  "comments": {
    "lineComment": "#",
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{",   "close": "}" },
    { "open": "[",   "close": "]" },
    { "open": "(",   "close": ")" },
    { "open": "'",   "close": "'",   "notIn": ["string"] },
    { "open": "\"",  "close": "\"",  "notIn": ["string"] },
    { "open": "`",   "close": "`",   "notIn": ["string"] },
    { "open": "/**", "close": " */", "notIn": ["string"] }
  ],
  "autoCloseBefore": ";:.,=}])> \n\t",
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "onEnterRules": [
    // e.g. /** | */
    {
      "beforeText": {
        "pattern": "^\\s*/\\*\\*(?!/)([^\\*]|\\*(?!/))*$"
      },
      "afterText": {
        "pattern": "^\\s*\\*/$"
      },
      "action": {
        "indent": "indentOutdent",
        "appendText": " * "
      }
    },
    // e.g. /** ...|
    {
      "beforeText": "^\\s*/\\*\\*(?!/)(.*)$",
      "previousLineText": {
        "pattern": "(?=^(\\s*(/\\*\\*|\\*)).*)(?=(?!(\\s*\\*/)))"
      },
      "action": {
        "indent": "none",
        "appendText": " * "
      }
    },
    // e.g.  * ...|
    {
      "beforeText": "^\\s*\\*(?!/)(.*)$",
      "previousLineText": {
        "pattern": "(?=^(\\s*(/\\*\\*|\\*)).*)(?=(?!(\\s*\\*/)))"
      },
      "action": {
        "indent": "none",
        "appendText": "* "
      }
    },
    // e.g.  */|
    {
      "beforeText": {
        "pattern": "^(\\t| {2})* \\*/\\s*$"
      },
      "action": {
        "indent": "none",
        "removeText": 1
      }
    },
    {
			// e.g.  *-----*/|
			"beforeText": {
				"pattern": "^(\\t|[ ])*[ ]\\*[^/]*\\*/\\s*$"
			},
			"action": {
				"indent": "none",
				"removeText": 1
			},
		},
    // Add // when pressing enter from inside line comment
    {
      "beforeText": {
        "pattern": "(?<!\\\\)(?<!\\w:)//.*"
      },
      "afterText": {
        "pattern": "^(?!\\s*$).+"
      },
      "action": {
        "indent": "none",
        "appendText": "// "
      }
    }
  ]
}
